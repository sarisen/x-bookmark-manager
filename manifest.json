{
  "manifest_version": 3,
  "name": "X Bookmarks Manager",
  "version": "1.3.0",
  "description": "X (Twitter) yer işaretleri sayfasını modern bir masonry görünümüyle değiştirir ve JSON olarak dışa aktarma imkânı sunar.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/bookmarks*",
        "https://twitter.com/i/bookmarks*"
      ],
      "js": ["content/parser.js", "content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/inject.js"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
